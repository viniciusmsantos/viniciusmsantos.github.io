---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import PostList from '../../components/PostList.astro';
import { resolveCover } from '../_imageStore';

const allWeekly = await getCollection('weekly');
const sorted = allWeekly.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const weeklyData = sorted.map((p) => ({
  ...p,
  slug: p.id,
  data: {
    ...p.data,
    category: 'Semanal',
    cover: resolveCover('weekly', p.id, p.data.cover),
  },
}));
---

<BlogLayout title="Semanal">
  <h1 class="text-2xl font-bold mb-8 flex items-center gap-2">
    <span class="w-1 h-6 bg-primary rounded-full inline-block"></span>
    <span data-pt="Semanal" data-en="Weekly">Semanal</span>
  </h1>
  <PostList posts={weeklyData as any} routePrefix="/weekly/" />
</BlogLayout>
