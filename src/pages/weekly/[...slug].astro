---
import { getCollection, getEntry, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { getReadingTime, getWordCount } from '../../utils/readingTime';
import { resolveCover } from '../_imageStore';

export async function getStaticPaths() {
  const posts = await getCollection('weekly');
  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const { slug } = Astro.params;
const post = await getEntry('weekly', slug!);

if (!post) {
  return Astro.redirect('/404');
}

const coverSrc = resolveCover('weekly', post.id, post.data.cover);

const { Content, headings } = await render(post);

const body = post.body || '';
const wordCount = getWordCount(body);
const readingTime = getReadingTime(body);

function formatDate(d: Date) {
  return d.toISOString().split('T')[0];
}
---

<PostLayout title={post.data.title} description={post.data.description} headings={headings} cover={post.data.cover}>
  <header class="mb-8">
    <span class="inline-block text-sm font-medium text-primary bg-primary/10 px-3 py-1 rounded-full mb-4">
      <span data-pt={`Semanal #${post.data.issue}`} data-en={`Weekly #${post.data.issue}`}>Semanal #{post.data.issue}</span>
    </span>
    <h1 class="text-3xl font-bold mb-4">{post.data.title}</h1>
    <div class="flex flex-wrap items-center gap-4 text-sm text-gray-400 dark:text-gray-500">
      <time datetime={formatDate(post.data.date)}>
        {formatDate(post.data.date)}
      </time>
      <span>{wordCount} <span data-pt="palavras" data-en="words">palavras</span></span>
      <span>{readingTime} min read</span>
    </div>
  </header>
  <Content />
</PostLayout>
