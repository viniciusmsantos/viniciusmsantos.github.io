---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Comment from '@/components/waline/Comment.astro';
import fs from 'node:fs';
import path from 'node:path';
import { friendCircleServer } from '../consts.ts';

interface FriendArticle {
  title: string;
  created: string;
  link: string;
  author: string;
  avatar: string;
}

interface FriendStats {
  friends_num: number;
  active_num: number;
  error_num: number;
  article_num: number;
  last_updated_time: string;
}

interface FriendData {
  statistical_data: FriendStats;
  article_data: FriendArticle[];
}

interface FriendLink {
  name: string;
  link: string;
  avatar: string;
  intro: string;
}

interface SpecialLink {
  name: string;
  intro: string;
  link: string;
  avatar: string;
}

interface LinksData {
  friends: {
    id_name: string;
    desc: string;
    link_list: (FriendLink | SpecialLink)[];
  }[];
}

const linksJsonPath = path.join(process.cwd(), 'public', 'links.json');
const linksData: LinksData = JSON.parse(fs.readFileSync(linksJsonPath, 'utf-8'));
const friendGroup = linksData.friends.find((g) => g.id_name === 'cf-links');
const specialGroup = linksData.friends.find((g) => g.id_name === 'special-links');
const friendList = (friendGroup?.link_list || []) as FriendLink[];
const specialList = (specialGroup?.link_list || []) as SpecialLink[];

const API_URL = friendCircleServer + '/all.json';// friend-circle-lite 服务的json数据
let data: FriendData | null = null;
let fetchError = false;

try {
  const res = await fetch(API_URL, {
    headers: { 'Accept': 'application/json' },
  });
  if (res.ok) {
    data = await res.json();
  } else {
    fetchError = true;
  }
} catch {
  fetchError = true;
}

const stats = data?.statistical_data;
const articles = data?.article_data || [];
---

<BaseLayout title="Links">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-8">
    <header class="mb-10">
      <p class="text-sm text-primary font-medium mb-2 tracking-wide uppercase">Links</p>
      <h1 class="text-3xl sm:text-4xl font-bold mb-3" data-pt="Links Recomendados" data-en="Recommended Links">Links Recomendados</h1>
      <p class="text-gray-500 dark:text-gray-400" data-pt="Alguns links úteis e blogs recomendados" data-en="Some useful links and recommended blogs">
        Alguns links úteis e blogs recomendados
      </p>
    </header>

    {
      friendList.length > 0 && (
        <div class="mb-8">
          <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
            <span class="w-1 h-5 bg-primary rounded-full inline-block"></span>
            <span data-pt="Recomendações" data-en="Recommendations">Recomendações</span>
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
            {friendList.map((friend) => (
              <a
                href={friend.link}
                target="_blank"
                rel="noopener noreferrer"
                class="card-hover bg-white dark:bg-[var(--color-card-dark)] rounded-xl shadow-sm p-4 flex flex-col items-center text-center group friend-card"
                data-url={friend.link}
              >
                <div class="relative">
                  <img
                    src={friend.avatar}
                    alt={friend.name}
                    class="w-14 h-14 rounded-full object-cover mb-2 ring-2 ring-primary/10 group-hover:ring-primary/30 transition-all"
                    loading="lazy"
                    width="56"
                    height="56"
                    onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 56 56%22><rect fill=%22%23e9536a%22 width=%2256%22 height=%2256%22 opacity=%22.2%22/><circle fill=%22%23e9536a%22 cx=%2228%22 cy=%2221%22 r=%2211%22/><ellipse fill=%22%23e9536a%22 cx=%2228%22 cy=%2249%22 rx=%2217%22 ry=%2214%22/></svg>'"
                  />
                  <span class="friend-status absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 rounded-full border-2 border-white dark:border-[var(--color-card-dark)] bg-gray-300" />
                </div>
                <span class="text-sm font-medium group-hover:text-primary transition-colors">
                  {friend.name}
                </span>
                <p class="text-xs text-gray-400 dark:text-gray-500 mt-1 line-clamp-2">
                  {friend.intro}
                </p>
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      specialList.length > 0 && (
        <div class="mb-8">
          <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
            <span class="w-1 h-5 bg-green-500 rounded-full inline-block"></span>
            <span data-pt="Especiais" data-en="Special Links">Especiais</span>
          </h2>
          <div class="grid grid-cols-2 gap-3">
            {specialList.map((item) => (
              <a
                href={item.link}
                target="_blank"
                rel="noopener noreferrer"
                class="card-hover bg-white dark:bg-[var(--color-card-dark)] rounded-xl shadow-sm p-4 flex items-center gap-3 group"
              >
                <img
                  src={item.avatar}
                  alt={item.name}
                  class="w-8 h-8 rounded-full object-cover shrink-0"
                  loading="lazy"
                  width="32"
                  height="32"
                  onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 32 32%22><rect fill=%22%2322c55e%22 width=%2232%22 height=%2232%22 opacity=%22.2%22/><circle fill=%22%2322c55e%22 cx=%2216%22 cy=%2212%22 r=%226%22/><ellipse fill=%22%2322c55e%22 cx=%2216%22 cy=%2228%22 rx=%2210%22 ry=%228%22/></svg>'"
                />
                <div class="flex-1 min-w-0">
                  <span class="text-sm font-medium group-hover:text-green-500 transition-colors">
                    {item.name}
                  </span>
                  <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5 line-clamp-2">
                    {item.intro}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      fetchError && (
        <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-6 text-center text-amber-700 dark:text-amber-400 mb-8">
          <p class="font-semibold" data-pt="Não foi possível conectar ao servidor de links" data-en="Could not connect to links server">Não foi possível conectar ao servidor de links</p>
          <p class="text-sm mt-1">URL: {API_URL}</p>
        </div>
      )
    }

    {
      stats && (
        <>
          <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
            <span class="w-1 h-5 bg-blue-500 rounded-full inline-block"></span>
            <span data-pt="Estatísticas dos Círculos" data-en="Friend Circle Stats">Estatísticas dos Círculos</span>
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
          <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-xl shadow-sm p-4 text-center">
            <div class="text-2xl font-bold text-primary">{stats.friends_num}</div>
            <div class="text-xs text-gray-400 dark:text-gray-500 mt-1" data-pt="Total de Links" data-en="Total Links">Total de Links</div>
          </div>
          <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-xl shadow-sm p-4 text-center">
            <div class="text-2xl font-bold text-green-500">{stats.active_num}</div>
            <div class="text-xs text-gray-400 dark:text-gray-500 mt-1" data-pt="Links Ativos" data-en="Active Links">Links Ativos</div>
          </div>
          <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-xl shadow-sm p-4 text-center">
            <div class="text-2xl font-bold text-blue-500">{stats.article_num}</div>
            <div class="text-xs text-gray-400 dark:text-gray-500 mt-1" data-pt="Total de Artigos" data-en="Total Articles">Total de Artigos</div>
          </div>
          <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-xl shadow-sm p-4 text-center">
            <div class="text-sm font-semibold text-gray-500 dark:text-gray-400 mt-1">{stats.last_updated_time}</div>
            <div class="text-xs text-gray-400 dark:text-gray-500 mt-1" data-pt="Última Atualização" data-en="Last Updated">Última Atualização</div>
          </div>
          </div>
        </>
      )
    }

    {
      articles.length > 0 && (
        <div class="space-y-3">
          {articles.map((article) => (
            <a
              href={article.link}
              target="_blank"
              rel="noopener noreferrer"
              class="card-hover flex items-center gap-4 bg-white dark:bg-[var(--color-card-dark)] rounded-xl shadow-sm p-4 group"
            >
              <img
                src={article.avatar}
                alt={article.author}
                class="w-10 h-10 rounded-full object-cover shrink-0 ring-2 ring-primary/10"
                loading="lazy"
                width="40"
                height="40"
                onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 40 40%22><rect fill=%22%23e9536a%22 width=%2240%22 height=%2240%22 opacity=%22.2%22/><circle fill=%22%23e9536a%22 cx=%2220%22 cy=%2215%22 r=%228%22/><ellipse fill=%22%23e9536a%22 cx=%2220%22 cy=%2235%22 rx=%2212%22 ry=%2210%22/></svg>'"
              />
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-medium truncate group-hover:text-primary transition-colors">
                  {article.title}
                </h3>
                <div class="flex items-center gap-3 mt-1 text-xs text-gray-400 dark:text-gray-500">
                  <span class="truncate">{article.author}</span>
                  <span class="w-px h-3 bg-gray-300 dark:bg-gray-600"></span>
                  <span class="shrink-0">{article.created}</span>
                </div>
              </div>
              <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 shrink-0 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          ))}
        </div>
      )
    }

    {
      !fetchError && !stats && (
        <div class="text-center py-12 text-gray-400">
          <p data-pt="Nenhum dado de link encontrado" data-en="No link data found">Nenhum dado de link encontrado</p>
        </div>
      )
    }

    <div class="mt-10 pt-8 border-t border-gray-100 dark:border-gray-800">
      <Comment />
    </div>
  </div>
</BaseLayout>

<script is:inline>
  (function() {
    function init() {
      var cards = document.querySelectorAll('.friend-card');
      var urls = [];
      cards.forEach(function(card) {
        var url = card.getAttribute('data-url');
        if (url) urls.push(url);
      });

      urls.forEach(function(url) {
        var card = document.querySelector('.friend-card[data-url="' + url + '"]');
        var statusDot = card?.querySelector('.friend-status');
        if (!statusDot) return;

        fetch(url, { method: 'HEAD', mode: 'no-cors', signal: AbortSignal.timeout(5000) })
          .then(function() {
            statusDot.classList.remove('bg-gray-300');
            statusDot.classList.add('bg-green-500');
          })
          .catch(function() {
            statusDot.classList.remove('bg-gray-300');
            statusDot.classList.add('bg-red-500');
          });
      });
    }

    init();
    document.addEventListener('astro:after-swap', init);
  })();
</script>
