---
import { getCollection } from 'astro:content';
import BlogLayout from '@/layouts/BlogLayout.astro';
import PostList from '@/components/PostList.astro';
import { resolveCover } from '@/pages/_imageStore';

const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const postData = sorted.map((p) => ({
  ...p,
  slug: p.id,
  data: {
    ...p.data,
    cover: resolveCover('blog', p.id, p.data.cover),
  },
}));

const totalPosts = allPosts.length;
const categories = new Set(allPosts.map(p => p.data.category).filter(Boolean)).size;
const tags = new Set(allPosts.flatMap(p => p.data.tags || [])).size;
---

<BlogLayout title="Artigos">
  <header class="mb-10">
    <p class="text-sm text-primary font-medium mb-2 tracking-wide uppercase">Archives</p>
    <h1 class="text-3xl sm:text-4xl font-bold mb-3" data-pt="Arquivo de Artigos" data-en="Article Archives">Arquivo de Artigos</h1>
    <p class="text-gray-500 dark:text-gray-400">
      <span data-pt="Total de" data-en="Total of">Total de</span>
      <span class="text-primary font-semibold">{totalPosts}</span>
      <span data-pt="artigos," data-en="articles,">artigos,</span>
      <span class="text-primary font-semibold">{categories}</span>
      <span data-pt="categorias," data-en="categories,">categorias,</span>
      <span class="text-primary font-semibold">{tags}</span>
      <span data-pt="tags" data-en="tags">tags</span>
    </p>
  </header>
  <PostList posts={postData} />
</BlogLayout>
