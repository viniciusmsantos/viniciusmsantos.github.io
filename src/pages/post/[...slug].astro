---
import { getCollection, getEntry, render } from 'astro:content';
import PostLayout from '@/layouts/PostLayout.astro';
import { getReadingTime, getWordCount } from '@/utils/readingTime';
import { resolveCover } from '@/pages/_imageStore';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug!);

if (!post) {
  return Astro.redirect('/404');
}

const coverSrc = resolveCover('blog', post.id, post.data.cover);

const { Content, headings } = await render(post);

const body = post.body || '';
const wordCount = getWordCount(body);
const readingTime = getReadingTime(body);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  headings={headings}
  cover={coverSrc}
  series={post.data.series}
  currentSlug={post.id}
  date={post.data.date}
  category={post.data.category}
  tags={post.data.tags}
>
  {post.data.draft && (
    <div class="mb-6">
      <span class="inline-flex items-center gap-0.5 text-sm font-medium text-gray-500 bg-gray-100 dark:bg-gray-800 dark:text-gray-400 px-3 py-1 rounded-full">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        <span data-pt="Em edição" data-en="Draft">Em edição</span>
      </span>
    </div>
  )}
  <Content />
</PostLayout>
