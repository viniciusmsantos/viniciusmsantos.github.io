---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ReadingProgress from '@/components/ReadingProgress.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import ShareButtons from '@/components/ShareButtons.astro';
import SeriesList from '@/components/SeriesList.astro';
import Comment from '@/components/waline/Comment.astro';
interface MarkdownHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  headings: MarkdownHeading[];
  cover?: string;
  series?: string;
  currentSlug?: string;
  date?: Date;
  category?: string;
  tags?: string[];
}

const {title, description, headings, cover, series, currentSlug, date, category, tags} = Astro.props;
const hasHeadings = headings && headings.length > 0;

function formatDate(d: Date) {
  return d.toISOString().split('T')[0];
}
---

<BaseLayout title={title} description={description} ogType="article" image={cover}>
  <ReadingProgress />

  <section class:list={['relative overflow-hidden', cover ? 'min-h-[60vh] sm:min-h-[70vh] flex items-end' : '']} data-hero>
    {cover ? (
      <>
        <div class="absolute inset-0" data-hero-parallax>
          <img
            src={cover}
            alt={title}
            class="w-full h-full object-cover scale-110"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/20"></div>
        </div>

        <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20 text-white w-full">
          <div class="hero-reveal" data-hero-reveal>
            {category && (
              <a href={`/categories/${category}`} class="inline-block text-xs font-medium text-primary bg-white/10 backdrop-blur-sm px-3 py-1 rounded-full mb-4 hover:bg-white/20 transition-colors">
                {category}
              </a>
            )}
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 tracking-tight leading-tight">
              {title}
            </h1>
            {description && (
              <p class="text-lg text-white/70 font-light mb-6 leading-relaxed max-w-2xl">
                {description}
              </p>
            )}
            <div class="flex flex-wrap items-center gap-4 text-sm text-white/50">
              {date && <time datetime={formatDate(date)}>{formatDate(date)}</time>}
              {tags && tags.length > 0 && (
                <div class="flex items-center gap-2">
                  {tags.map((tag) => (
                    <a href={`/tags/${tag}`} class="hover:text-primary transition-colors">
                      #{tag}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      </>
    ) : (
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 pt-8 pb-4 w-full">
        {category && (
          <a href={`/categories/${category}`} class="inline-block text-xs font-medium text-primary bg-primary/10 px-3 py-1 rounded-full mb-4">
            {category}
          </a>
        )}
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 tracking-tight leading-tight">
          {title}
        </h1>
        {description && (
          <p class="text-lg text-gray-500 dark:text-gray-400 font-light mb-4 leading-relaxed max-w-2xl">
            {description}
          </p>
        )}
        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-400 dark:text-gray-500">
          {date && <time datetime={formatDate(date)}>{formatDate(date)}</time>}
          {tags && tags.length > 0 && (
            <div class="flex items-center gap-2">
              {tags.map((tag) => (
                <a href={`/tags/${tag}`} class="hover:text-primary transition-colors">
                  #{tag}
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    )}
  </section>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row gap-8 py-8">
      <div class="flex-1 min-w-0 order-1">
        <article class="prose max-w-none">
          <slot/>
        </article>
        <div class="mt-8">
          <ShareButtons title={title} />
        </div>
        <div class="mt-10 pt-8 border-t border-gray-100 dark:border-gray-800">
          <Comment />
        </div>
      </div>
      {
        hasHeadings && (
          <aside class="w-full lg:w-60 shrink-0 order-2">
            <div class="sticky top-24 space-y-4">
              <TableOfContents headings={headings}/>
              {series && currentSlug && (
                <SeriesList series={series} currentSlug={currentSlug} />
              )}
            </div>
          </aside>
        )
      }
      {
        (!hasHeadings) && series && currentSlug && (
          <aside class="w-full lg:w-60 shrink-0 order-2">
            <div class="sticky top-24">
              <SeriesList series={series} currentSlug={currentSlug} />
            </div>
          </aside>
        )
      }
    </div>
  </div>

  {
    hasHeadings && (
      <>
        <button
          id="mobile-toc-trigger"
          class="lg:hidden fixed bottom-20 left-4 z-40 flex items-center gap-1.5 px-3 py-2.5 bg-white dark:bg-[var(--color-card-dark)] text-primary rounded-full shadow-lg border border-gray-100 dark:border-gray-700 text-sm font-medium transition-all hover:shadow-xl"
          aria-label="Abrir índice"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
          </svg>
          <span data-pt="Índice" data-en="Contents">Índice</span>
        </button>

        <div
          id="mobile-toc-drawer"
          class="lg:hidden fixed inset-0 z-50 pointer-events-none"
          aria-hidden="true"
          inert
        >
          <div id="mobile-toc-backdrop" class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-300"></div>
          <div id="mobile-toc-panel" class="absolute bottom-0 left-0 right-0 max-h-[70vh] bg-white dark:bg-[var(--color-bg-dark)] rounded-t-2xl shadow-2xl transform translate-y-full transition-transform duration-300 overflow-hidden flex flex-col">
            <div class="flex items-center justify-between px-5 py-3 border-b border-gray-100 dark:border-gray-700 shrink-0">
              <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100" data-pt="Índice" data-en="Contents">Índice</h2>
              <button
                id="mobile-toc-close"
                class="p-2 -mr-2 rounded-lg text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors"
                aria-label="Fechar índice"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            <div class="overflow-y-auto flex-1 p-4">
              <TableOfContents headings={headings} mobile={true}/>
            </div>
          </div>
        </div>
      </>
    )
  }
</BaseLayout>

<script is:inline>
  (function() {
    function init() {
      var trigger = document.getElementById('mobile-toc-trigger');
      var drawer = document.getElementById('mobile-toc-drawer');
      var backdrop = document.getElementById('mobile-toc-backdrop');
      var panel = document.getElementById('mobile-toc-panel');
      var closeBtn = document.getElementById('mobile-toc-close');
      if (!trigger || !drawer || !backdrop || !panel) return;

      function openDrawer() {
        drawer.removeAttribute('inert');
        drawer.setAttribute('aria-hidden', 'false');
        drawer.classList.remove('pointer-events-none');
        backdrop.classList.remove('opacity-0');
        backdrop.classList.add('opacity-100');
        panel.classList.remove('translate-y-full');
        document.body.style.overflow = 'hidden';
      }

      function closeDrawer() {
        backdrop.classList.remove('opacity-100');
        backdrop.classList.add('opacity-0');
        panel.classList.add('translate-y-full');
        setTimeout(function() {
          drawer.setAttribute('inert', '');
          drawer.setAttribute('aria-hidden', 'true');
          drawer.classList.add('pointer-events-none');
          document.body.style.overflow = '';
        }, 300);
      }

      trigger.addEventListener('click', openDrawer);
      closeBtn?.addEventListener('click', closeDrawer);
      backdrop.addEventListener('click', closeDrawer);

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && drawer.getAttribute('aria-hidden') === 'false') {
          closeDrawer();
        }
      });
    }

    init();
    document.addEventListener('astro:after-swap', init);
  })();
</script>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initHero() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    gsap.registerPlugin(ScrollTrigger);

    const hero = document.querySelector('[data-hero]');
    const parallaxLayer = document.querySelector('[data-hero-parallax]');
    const reveals = document.querySelectorAll('[data-hero-reveal]');

    if (!hero || !parallaxLayer) return;

    gsap.fromTo(parallaxLayer,
      { y: 0 },
      {
        y: 50,
        ease: 'none',
        scrollTrigger: {
          trigger: hero,
          start: 'top top',
          end: 'bottom top',
          scrub: true,
        },
      }
    );

    if (reveals.length > 0) {
      gsap.fromTo(reveals,
        { opacity: 0, y: 20 },
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          stagger: 0.1,
          ease: 'power3.out',
          delay: 0.1,
        }
      );
    }
  }

  initHero();
  document.addEventListener('astro:after-swap', () => {
    setTimeout(initHero, 100);
  });
</script>
