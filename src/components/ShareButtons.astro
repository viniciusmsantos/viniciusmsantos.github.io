---
interface Props {
  title: string;
  url?: string;
}

const { title, url } = Astro.props;
const shareUrl = url || Astro.url.href;
const encodedUrl = encodeURIComponent(shareUrl);
const encodedTitle = encodeURIComponent(title);
---

<div class="flex items-center gap-2">
  <span class="text-sm text-gray-400 dark:text-gray-500" data-pt="Compartilhar" data-en="Share">Compartilhar</span>

  <a
    href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center justify-center w-11 h-11 rounded-lg text-gray-400 dark:text-gray-500 hover:text-[#1DA1F2] hover:bg-[#1DA1F2]/10 transition-colors"
    aria-label="Compartilhar no Twitter"
  >
    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
    </svg>
  </a>

  <button
    id="share-wechat"
    class="flex items-center justify-center w-11 h-11 rounded-lg text-gray-400 dark:text-gray-500 hover:text-green-500 hover:bg-green-500/10 transition-colors relative"
    aria-label="Compartilhar no WeChat"
    data-url={shareUrl}
    data-title={title}
  >
    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
      <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05a6.329 6.329 0 0 1-.256-1.787c0-3.614 3.342-6.555 7.465-6.555.26 0 .512.022.77.05C16.836 4.99 13.122 2.188 8.691 2.188zM5.785 7.05a1.128 1.128 0 1 1 0-2.256 1.128 1.128 0 0 1 0 2.256zm5.812 0a1.128 1.128 0 1 1 0-2.256 1.128 1.128 0 0 1 0 2.256zm3.27 3.296c-3.578 0-6.481 2.535-6.481 5.663 0 3.128 2.903 5.663 6.481 5.663a7.823 7.823 0 0 0 2.193-.314.672.672 0 0 1 .556.076l1.478.865a.253.253 0 0 0 .13.042.228.228 0 0 0 .226-.228c0-.056-.023-.11-.038-.165l-.304-1.15a.457.457 0 0 1 .165-.516c1.426-1.05 2.34-2.593 2.34-4.298 0-3.128-2.903-5.663-6.481-5.663h-.487zm-2.508 3.033a.878.878 0 1 1 0-1.757.878.878 0 0 1 0 1.757zm5.017 0a.878.878 0 1 1 0-1.757.878.878 0 0 1 0 1.757z" />
    </svg>
    <div
      id="wechat-qrcode"
      class="hidden absolute bottom-full left-1/2 -translate-x-1/2 mb-2 p-3 bg-white rounded-xl shadow-xl border border-gray-100 dark:border-gray-700 z-50"
    >
      <div class="text-xs text-gray-500 mb-2 text-center" data-pt="Escaneie com o WeChat para compartilhar" data-en="Scan with WeChat to share">Escaneie com WeChat</div>
      <img
        id="wechat-qrcode-img"
        class="w-32 h-32"
        alt="QR Code de compartilhamento"
      />
    </div>
  </button>

  <button
    id="share-copy-link"
    class="flex items-center justify-center w-11 h-11 rounded-lg text-gray-400 dark:text-gray-500 hover:text-primary hover:bg-primary/10 transition-colors"
    aria-label="Copiar link"
    data-url={shareUrl}
  >
    <svg class="w-5 h-5 share-copy-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
    </svg>
    <svg class="w-5 h-5 share-check-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
    </svg>
  </button>

  <button
    id="share-native"
    class="flex items-center justify-center w-11 h-11 rounded-lg text-gray-400 dark:text-gray-500 hover:text-primary hover:bg-primary/10 transition-colors hidden"
    aria-label="Compartilhar"
  >
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
    </svg>
  </button>
</div>

<script is:inline>
  (function() {
    function init() {
      var qrcodeImg = document.getElementById('wechat-qrcode-img');
      if (qrcodeImg) {
        var wechatBtn = document.getElementById('share-wechat');
        var wechatQrcode = document.getElementById('wechat-qrcode');
        var shareUrl = wechatBtn?.getAttribute('data-url') || window.location.href;
        qrcodeImg.src = 'https://api.qrserver.com/v1/create-qr-code/?size=128x128&data=' + encodeURIComponent(shareUrl);

        var isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;

        if (isTouchDevice) {
          wechatBtn?.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var isOpen = !wechatQrcode?.classList.contains('hidden');
            wechatQrcode?.classList.toggle('hidden', isOpen);
          });
        } else {
          wechatBtn?.addEventListener('mouseenter', function() {
            wechatQrcode?.classList.remove('hidden');
          });
          wechatBtn?.addEventListener('mouseleave', function() {
            wechatQrcode?.classList.add('hidden');
          });
        }
      }

      var copyBtn = document.getElementById('share-copy-link');
      copyBtn?.addEventListener('click', function() {
        var url = this.getAttribute('data-url') || window.location.href;
        navigator.clipboard.writeText(url).then(function() {
          var copyIcon = copyBtn.querySelector('.share-copy-icon');
          var checkIcon = copyBtn.querySelector('.share-check-icon');
          copyIcon?.classList.add('hidden');
          checkIcon?.classList.remove('hidden');
          setTimeout(function() {
            copyIcon?.classList.remove('hidden');
            checkIcon?.classList.add('hidden');
          }, 2000);
        });
      });

      var nativeBtn = document.getElementById('share-native');
      if (nativeBtn && navigator.share) {
        nativeBtn.classList.remove('hidden');
        nativeBtn.addEventListener('click', function() {
          var title = this.getAttribute('data-title') || document.title;
          navigator.share({ title: title, url: window.location.href });
        });
      }
    }

    init();
    document.addEventListener('astro:after-swap', init);
  })();
</script>
