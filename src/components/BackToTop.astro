<button
  id="back-to-top"
  class="fixed bottom-8 right-8 lg:bottom-8 lg:right-8 bottom-20 right-6 z-50 p-3 rounded-full bg-primary text-white shadow-lg opacity-0 invisible transition-all duration-300 hover:bg-primary/90"
  aria-label="Voltar ao topo"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M5 10l7-7m0 0l7 7m-7-7v18" />
  </svg>
</button>

<script is:inline>
  (function() {
    function init() {
      var btn = document.getElementById('back-to-top');
      if (!btn) return;

      function toggleButton() {
        var show = window.scrollY > 300;
        btn.classList.toggle('opacity-0', !show);
        btn.classList.toggle('invisible', !show);
      }

      window.addEventListener('scroll', toggleButton);

      btn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      toggleButton();
    }

    init();
    document.addEventListener('astro:after-swap', init);
  })();
</script>
