---
import { getCollection } from 'astro:content';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_AVATAR, SOCIAL_LINKS } from '@/consts';
import { getWordCount } from '@/utils/readingTime';

const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const totalPosts = sorted.length;
let totalWords = 0;
const categoryMap = new Map<
  string,
  { count: number; recentPosts: typeof allPosts; displayName: string }
>();
const tagMap = new Map<string, number>();

for (const post of sorted) {
  totalWords += getWordCount(post.body || '');

  const cat = post.data.category;
  if (cat) {
    const rootCat = cat.split('/')[0];
    if (!categoryMap.has(rootCat)) {
      categoryMap.set(rootCat, { count: 0, recentPosts: [], displayName: rootCat });
    }
    const entry = categoryMap.get(rootCat)!;
    entry.count++;
    if (entry.recentPosts.length < 3) {
      entry.recentPosts.push(post);
    }
  }

  for (const tag of post.data.tags || []) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}

const allCategories = Array.from(categoryMap.entries());
const allTags = Array.from(tagMap.entries()).sort((a, b) => b[1] - a[1]);

const CATEGORY_LIMIT = 5;
const TAG_LIMIT = 15;

const randomPosts = sorted
  .sort(() => Math.random() - 0.5)
  .slice(0, 5);

function slugify(post: (typeof sorted)[0]) {
  return post.id;
}
---

<aside class="space-y-5">
  <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-6 text-center border border-gray-100/50 dark:border-white/[0.05]">
    <div class="relative inline-block mb-3">
      <img
        src={SITE_AVATAR}
        alt={SITE_AUTHOR}
        class="w-20 h-20 rounded-full mx-auto object-cover ring-2 ring-primary/20 ring-offset-2 ring-offset-white dark:ring-offset-[var(--color-card-dark)]"
        width="80"
        height="80"
      />
      <div class="absolute bottom-0 right-0 w-5 h-5 bg-green-400 rounded-full border-2 border-white dark:border-[var(--color-card-dark)]"></div>
    </div>
    <h2 class="font-semibold text-base">{SITE_AUTHOR}</h2>
    <p class="text-xs text-gray-400 dark:text-gray-500 mt-1 leading-relaxed">{SITE_DESCRIPTION}</p>
    <div class="flex items-center justify-center gap-3 mt-4">
      {SOCIAL_LINKS.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="w-8 h-8 flex items-center justify-center rounded-full bg-gray-50 dark:bg-white/[0.03] text-gray-400 hover:text-primary hover:bg-primary/5 dark:hover:bg-primary/10 transition-all"
          title={link.name}
        >
          {link.icon === 'github' && (
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          )}
          {link.icon === 'linkedin' && (
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          )}
          {link.icon === 'email' && (
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          )}
          {link.icon === 'rss' && (
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
          )}
        </a>
      ))}
    </div>

    <div class="flex items-center justify-center gap-6 mt-4 pt-4 border-t border-gray-100 dark:border-gray-800/50">
      <a href="/archives" class="text-center group">
        <div class="font-semibold text-sm group-hover:text-primary transition-colors">{totalPosts}</div>
        <div class="text-[10px] text-gray-400 uppercase tracking-wider" data-pt="Artigos" data-en="Posts">Artigos</div>
      </a>
      <div class="w-px h-6 bg-gray-100 dark:bg-gray-800/50"></div>
      <a href="/archives" class="text-center group">
        <div class="font-semibold text-sm group-hover:text-primary transition-colors">{Math.round(totalWords / 1000)}k</div>
        <div class="text-[10px] text-gray-400 uppercase tracking-wider" data-pt="Palavras" data-en="Words">Palavras</div>
      </a>
    </div>
  </div>

  {
    allCategories.length > 0 && (
      <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-5 border border-gray-100/50 dark:border-white/[0.05]"
        data-sidebar-section="categories"
      >
        <h2 class="text-xs font-semibold mb-3 text-gray-400 dark:text-gray-500 uppercase tracking-wider" data-pt="Categorias" data-en="Categories">
          Categorias
        </h2>
        <div class="sidebar-expand-list flex flex-wrap gap-2">
          {allCategories.map(([name, info], i) => (
            <a
              href={`/categories/${name}`}
              class={`text-xs px-3 py-1.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-primary hover:text-white dark:hover:bg-primary transition-colors ${
                i >= CATEGORY_LIMIT ? 'hidden sidebar-extra' : ''
              }`}
            >
              {info.displayName}
              <span class="ml-1 opacity-60">({info.count})</span>
            </a>
          ))}
        </div>
        {
          allCategories.length > CATEGORY_LIMIT && (
            <button
              type="button"
              class="sidebar-toggle-btn mt-3 text-xs text-primary hover:underline"
              data-expanded="false"
              data-pt={`Mostrar todas (${allCategories.length})`}
              data-en={`Show all (${allCategories.length})`}
            >
              Mostrar todas ({allCategories.length})
            </button>
          )
        }
      </div>
    )
  }

  {
    allTags.length > 0 && (
      <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-5 border border-gray-100/50 dark:border-white/[0.05]"
        data-sidebar-section="tags"
      >
        <h2 class="text-xs font-semibold mb-3 text-gray-400 dark:text-gray-500 uppercase tracking-wider" data-pt="Tags" data-en="Tags">
          Tags
        </h2>
        <div class="sidebar-expand-list flex flex-wrap gap-2">
          {allTags.map(([tag, count], i) => (
            <a
              href={`/tags/${tag}`}
              class={`text-xs px-3 py-1.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-primary hover:text-white dark:hover:bg-primary transition-colors ${
                i >= TAG_LIMIT ? 'hidden sidebar-extra' : ''
              }`}
            >
              {tag}
              <span class="ml-1 opacity-60">({count})</span>
            </a>
          ))}
        </div>
        {
          allTags.length > TAG_LIMIT && (
            <button
              type="button"
              class="sidebar-toggle-btn mt-3 text-xs text-primary hover:underline"
              data-expanded="false"
              data-pt={`Mostrar todas (${allTags.length})`}
              data-en={`Show all (${allTags.length})`}
            >
              Mostrar todas ({allTags.length})
            </button>
          )
        }
      </div>
    )
  }

  {
    randomPosts.length > 0 && (
      <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-5 border border-gray-100/50 dark:border-white/[0.05]">
        <h2 class="text-xs font-semibold mb-4 text-gray-400 dark:text-gray-500 uppercase tracking-wider" data-pt="Recomendados" data-en="Random Posts">
          Recomendados
        </h2>
        <div class="space-y-2">
          {randomPosts.map((post) => (
            <a
              href={`/post/${slugify(post)}`}
              class="block text-xs text-gray-500 dark:text-gray-400 truncate hover:text-primary transition-colors"
            >
              {post.data.title}
            </a>
          ))}
        </div>
      </div>
    )
  }
</aside>

<script is:inline>
  function initSidebarToggles() {
    document.querySelectorAll('.sidebar-toggle-btn').forEach((btn) => {
      if (btn.dataset.initialized) return;
      btn.dataset.initialized = 'true';

      const section = btn.closest('[data-sidebar-section]');
      if (!section) return;
      const list = section.querySelector('.sidebar-expand-list');
      if (!list) return;
      const extraItems = list.querySelectorAll('.sidebar-extra');
      const label = btn.textContent || '';

      btn.addEventListener('click', () => {
        const expanded = btn.dataset.expanded === 'true';
        extraItems.forEach((el) => el.classList.toggle('hidden', expanded));
        btn.dataset.expanded = String(!expanded);
        
        var locale = localStorage.getItem('locale') || 'pt';
        var collapseText = locale === 'en' ? 'Collapse' : 'Recolher';
        btn.textContent = expanded ? label : collapseText;
      });
    });
  }

  document.addEventListener('astro:page-load', initSidebarToggles);
  initSidebarToggles();
</script>
