---
import { SITE_TITLE, NAV_ITEMS } from '@/consts';
import Search from '@/components/Search.astro';
import LanguageSwitcher from '@/components/LanguageSwitcher.astro';

function isArticleLabel(item: typeof NAV_ITEMS[number]) {
  return item.label === 'Artigos';
}

const navTranslations: Record<string, { pt: string; en: string }> = {
  'Início': { pt: 'Início', en: 'Home' },
  // 'Semanal': { pt: 'Semanal', en: 'Weekly' },
  'Artigos': { pt: 'Artigos', en: 'Archives' },
  // 'Links': { pt: 'Links', en: 'Friends' },
  'Sobre': { pt: 'Sobre', en: 'About' },
  'Categorias': { pt: 'Categorias', en: 'Categories' },
  'Tags': { pt: 'Tags', en: 'Tags' },
  'Arquivo': { pt: 'Arquivo', en: 'Archives' },
};
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div id="nav-container" class="flex items-center justify-between h-16 transition-all duration-500">
      <a href="/" class="flex items-center gap-2 shrink-0">
        <span class="text-xl font-bold text-primary hover:opacity-80 transition-opacity">
          {SITE_TITLE}
        </span>
      </a>

      <nav class="hidden md:flex items-center gap-1" aria-label="Navegação Principal">
        {NAV_ITEMS.map((item) => (
          isArticleLabel(item) ? (
            <div class="relative group">
              <span class="px-3 py-2 text-sm font-medium rounded-lg text-gray-600 dark:text-gray-300 group-hover:text-primary dark:group-hover:text-primary group-hover:bg-primary/5 transition-colors cursor-pointer flex items-center gap-1">
                <span class="nav-text" data-pt={item.label} data-en={navTranslations[item.label]?.en || item.label}>{item.label}</span>
                <svg class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
              <div class="absolute top-full left-0 mt-1 w-36 py-2 bg-white dark:bg-[var(--color-card-dark)] rounded-xl shadow-lg border border-gray-100 dark:border-gray-700 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <a href="/categories" class="block px-4 py-2 text-sm text-gray-600 dark:text-gray-300 hover:text-primary hover:bg-primary/5 transition-colors">
                  <span class="nav-text" data-pt="Categorias" data-en="Categories">Categorias</span>
                </a>
                <a href="/tags" class="block px-4 py-2 text-sm text-gray-600 dark:text-gray-300 hover:text-primary hover:bg-primary/5 transition-colors">
                  <span class="nav-text" data-pt="Tags" data-en="Tags">Tags</span>
                </a>
                <a href="/archives" class="block px-4 py-2 text-sm text-gray-600 dark:text-gray-300 hover:text-primary hover:bg-primary/5 transition-colors">
                  <span class="nav-text" data-pt="Arquivo" data-en="Archives">Arquivo</span>
                </a>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="px-3 py-2 text-sm font-medium rounded-lg text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-primary hover:bg-primary/5 transition-colors"
            >
              <span class="nav-text" data-pt={item.label} data-en={navTranslations[item.label]?.en || item.label}>{item.label}</span>
            </a>
          )
        ))}
      </nav>

      <div class="flex items-center gap-2">
        <button
          id="search-trigger"
          class="flex items-center gap-1.5 p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-label="Pesquisar"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <kbd class="hidden sm:inline-flex items-center text-[10px] font-medium text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded">⌘K</kbd>
        </button>

        <LanguageSwitcher />

        <button
          id="theme-toggle"
          class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-label="Alternar tema"
        >
          <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-label="Menu"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <nav class="flex flex-col gap-0.5">
        {NAV_ITEMS.map((item) => (
          <div>
            <a
              href={isArticleLabel(item) ? undefined : item.href}
              class={`flex items-center px-3 py-3 text-sm font-medium rounded-lg text-gray-600 dark:text-gray-300 hover:text-primary hover:bg-primary/5 transition-colors min-h-[44px] ${isArticleLabel(item) ? 'cursor-pointer' : ''}`}
            >
              <span class="nav-text" data-pt={item.label} data-en={navTranslations[item.label]?.en || item.label}>{item.label}</span>
            </a>
            {isArticleLabel(item) && (
              <div class="ml-4 space-y-0">
                <a href="/categories" class="flex items-center px-3 py-2.5 text-sm text-gray-500 dark:text-gray-400 hover:text-primary transition-colors min-h-[44px]">
                  <span class="nav-text" data-pt="Categorias" data-en="Categories">Categorias</span>
                </a>
                <a href="/tags" class="flex items-center px-3 py-2.5 text-sm text-gray-500 dark:text-gray-400 hover:text-primary transition-colors min-h-[44px]">
                  <span class="nav-text" data-pt="Tags" data-en="Tags">Tags</span>
                </a>
                <a href="/archives" class="flex items-center px-3 py-2.5 text-sm text-gray-500 dark:text-gray-400 hover:text-primary transition-colors min-h-[44px]">
                  <span class="nav-text" data-pt="Arquivo" data-en="Archives">Arquivo</span>
                </a>
              </div>
            )}
          </div>
        ))}
      </nav>
    </div>
  </div>
</header>

<Search />

<script is:inline>
  (function() {
    var header = document.getElementById('site-header');
    var container = document.getElementById('nav-container');
    if (!header || !container) return;

    var SCROLL_THRESHOLD = 100;
    var isPill = false;

    function updateNav() {
      var scrollY = window.scrollY;
      var shouldBePill = scrollY > SCROLL_THRESHOLD;

      if (shouldBePill !== isPill) {
        isPill = shouldBePill;
        if (isPill) {
          header.classList.add('backdrop-blur-md', 'bg-white/80', 'dark:bg-[var(--color-bg-dark)]/80', 'border-b', 'border-gray-200/50', 'dark:border-gray-700/50');
          header.style.top = '0';
          header.style.left = '0';
          header.style.right = '0';
          header.style.width = '100%';
          header.style.borderRadius = '0';
          container.style.maxWidth = '80rem';
        } else {
          header.classList.remove('backdrop-blur-md', 'bg-white/80', 'dark:bg-[var(--color-bg-dark)]/80', 'border-b', 'border-gray-200/50', 'dark:border-gray-700/50');
          header.style.top = '0';
          header.style.left = '0';
          header.style.right = '0';
          header.style.width = '100%';
          header.style.borderRadius = '0';
          container.style.maxWidth = '80rem';
        }
      }
    }

    var ticking = false;
    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(function() {
          updateNav();
          ticking = false;
        });
        ticking = true;
      }
    });

    updateNav();
  })();
</script>

<script is:inline>
  function handleThemeToggle(e) {
    var root = document.documentElement;
    var isDark = root.classList.contains('dark');

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      if (isDark) {
        root.classList.remove('dark');
        localStorage.theme = 'light';
      } else {
        root.classList.add('dark');
        localStorage.theme = 'dark';
      }
      return;
    }

    var btn = e.currentTarget;
    var rect = btn.getBoundingClientRect();
    var x = rect.left + rect.width / 2;
    var y = rect.top + rect.height / 2;
    var maxRadius = Math.sqrt(
      Math.pow(Math.max(x, window.innerWidth - x), 2) +
      Math.pow(Math.max(y, window.innerHeight - y), 2)
    ) * 1.2;

    var overlay = document.createElement('div');
    overlay.style.cssText = 'position:fixed;inset:0;z-index:9998;pointer-events:none;' +
      'clip-path:circle(0px at ' + x + 'px ' + y + 'px);' +
      'background:' + (isDark ? '#1a1a2e' : '#f5f5f5') + ';';
    document.body.appendChild(overlay);

    root.classList.add('theme-transitioning');

    requestAnimationFrame(function() {
      overlay.style.transition = 'clip-path 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
      overlay.style.clipPath = 'circle(' + maxRadius + 'px at ' + x + 'px ' + y + 'px)';

      setTimeout(function() {
        if (isDark) {
          root.classList.remove('dark');
          localStorage.theme = 'light';
        } else {
          root.classList.add('dark');
          localStorage.theme = 'dark';
        }
      }, 280);

      setTimeout(function() {
        overlay.style.opacity = '0';
        overlay.style.transition = 'opacity 0.4s ease';
      }, 600);

      setTimeout(function() {
        overlay.remove();
        root.classList.remove('theme-transitioning');
      }, 1000);
    });
  }

  function handleMobileMenu() {
    var menu = document.getElementById('mobile-menu');
    if (menu) {
      menu.classList.toggle('hidden');
    }
  }

  function applyNavTranslations() {
    var locale = localStorage.getItem('locale') || 'pt';
    document.querySelectorAll('.nav-text, [data-pt], [data-en]').forEach(function(el) {
      var text = el.getAttribute('data-' + locale);
      if (text) {
        if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
          el.placeholder = text;
        } else {
          el.textContent = text;
        }
      }
    });
  }

  function bindHandlers() {
    var themeBtn = document.getElementById('theme-toggle');
    var mobileBtn = document.getElementById('mobile-menu-btn');

    if (themeBtn) {
      themeBtn.removeEventListener('click', handleThemeToggle);
      themeBtn.addEventListener('click', handleThemeToggle);
    }

    if (mobileBtn) {
      mobileBtn.removeEventListener('click', handleMobileMenu);
      mobileBtn.addEventListener('click', handleMobileMenu);
    }

    applyNavTranslations();
  }

  bindHandlers();

  document.addEventListener('astro:after-swap', function() {
    bindHandlers();
  });
</script>
