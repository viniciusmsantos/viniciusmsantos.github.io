---
import Sidebar from '@/components/Sidebar.astro';
---

<button
  id="sidebar-toggle"
  class="lg:hidden fixed bottom-6 right-6 z-40 w-12 h-12 bg-primary text-white rounded-full shadow-lg flex items-center justify-center hover:bg-primary-dark transition-colors"
  aria-label="Abrir barra lateral"
>
  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7" />
  </svg>
</button>

<div
  id="sidebar-drawer"
  class="lg:hidden fixed inset-0 z-50 pointer-events-none"
  aria-hidden="true"
  inert
>
  <div
    id="sidebar-backdrop"
    class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-300"
  ></div>
  <div
    id="sidebar-panel"
    class="absolute right-0 top-0 h-full w-80 max-w-[85vw] bg-white dark:bg-[var(--color-bg-dark)] shadow-2xl transform translate-x-full transition-transform duration-300 overflow-y-auto"
  >
    <div class="p-4">
      <button
        id="sidebar-close"
        class="mb-4 p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        aria-label="Fechar barra lateral"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <Sidebar />
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    function init() {
      var toggle = document.getElementById('sidebar-toggle');
      var drawer = document.getElementById('sidebar-drawer');
      var backdrop = document.getElementById('sidebar-backdrop');
      var panel = document.getElementById('sidebar-panel');
      var close = document.getElementById('sidebar-close');
      if (!toggle || !drawer || !backdrop || !panel) return;

      function openSidebar() {
        drawer.removeAttribute('inert');
        drawer.setAttribute('aria-hidden', 'false');
        drawer.classList.remove('pointer-events-none');
        backdrop.classList.remove('opacity-0');
        backdrop.classList.add('opacity-100');
        panel.classList.remove('translate-x-full');
        document.body.style.overflow = 'hidden';
      }

      function closeSidebar() {
        backdrop.classList.remove('opacity-100');
        backdrop.classList.add('opacity-0');
        panel.classList.add('translate-x-full');
        setTimeout(function() {
          drawer.setAttribute('inert', '');
          drawer.setAttribute('aria-hidden', 'true');
          drawer.classList.add('pointer-events-none');
          document.body.style.overflow = '';
        }, 300);
      }

      toggle.removeEventListener('click', openSidebar);
      toggle.addEventListener('click', openSidebar);
      close?.removeEventListener('click', closeSidebar);
      close?.addEventListener('click', closeSidebar);
      backdrop.removeEventListener('click', closeSidebar);
      backdrop.addEventListener('click', closeSidebar);

      document.removeEventListener('keydown', handleEscape);
      document.addEventListener('keydown', handleEscape);
    }

    function handleEscape(e) {
      var drawer = document.getElementById('sidebar-drawer');
      if (e.key === 'Escape' && drawer?.getAttribute('aria-hidden') === 'false') {
        var backdrop = document.getElementById('sidebar-backdrop');
        var panel = document.getElementById('sidebar-panel');
        backdrop?.classList.remove('opacity-100');
        backdrop?.classList.add('opacity-0');
        panel?.classList.add('translate-x-full');
        setTimeout(function() {
          drawer?.setAttribute('inert', '');
          drawer?.setAttribute('aria-hidden', 'true');
          drawer?.classList.add('pointer-events-none');
          document.body.style.overflow = '';
        }, 300);
      }
    }

    init();
    document.addEventListener('astro:after-swap', init);
  })();
</script>
