---
import { getReadingTime, getWordCount } from '@/utils/readingTime';

interface Props {
  title: string;
  description?: string;
  date: Date;
  slug: string;
  tags?: string[];
  category?: string;
  cover?: string;
  body?: string;
  pinned?: boolean;
  draft?: boolean;
  routePrefix?: string;
}

const {
  title,
  description,
  date,
  slug,
  tags = [],
  category,
  cover,
  body,
  pinned = false,
  draft = false,
  routePrefix = '/post/',
} = Astro.props;

const wordCount = body ? getWordCount(body) : 0;
const readingTime = body ? getReadingTime(body) : 0;

function formatDate(d: Date) {
  return d.toISOString().split('T')[0];
}
---

<article
  class="card-tilt group relative bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm overflow-hidden border border-gray-100/50 dark:border-white/[0.05] hover:shadow-xl hover:border-gray-200/50 dark:hover:border-white/[0.08] transition-all duration-300"
  transition:animate="fade"
>
  <a href={`${routePrefix}${slug}`} class="block">
    {cover ? (
      <div class="aspect-[2/1] overflow-hidden relative">
        <img
          src={cover}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
      </div>
    ) : (
      <div class="aspect-[2/1] bg-gradient-to-br from-primary/8 via-primary/3 to-transparent relative overflow-hidden">
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="relative">
            <div class="absolute -inset-8 bg-primary/5 rounded-full blur-xl"></div>
            <span class="relative text-5xl font-bold text-primary/15 group-hover:text-primary/25 transition-colors duration-500">
              {title.charAt(0)}
            </span>
          </div>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary/10 to-transparent"></div>
      </div>
    )}

    <div class="p-5">
      <div class="flex items-center gap-2 mb-3">
        {category && (
          <span class="inline-flex items-center text-[11px] font-medium text-primary bg-primary/10 px-2.5 py-0.5 rounded-full">
            {category}
          </span>
        )}
        {pinned && (
          <span class="inline-flex items-center gap-0.5 text-[11px] font-medium text-amber-600 bg-amber-50 dark:bg-amber-900/20 dark:text-amber-400 px-2 py-0.5 rounded-full">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <span data-pt="Fixado" data-en="Pinned">Fixado</span>
          </span>
        )}
        {draft && (
          <span class="inline-flex items-center gap-0.5 text-[11px] font-medium text-gray-500 bg-gray-100 dark:bg-gray-800 dark:text-gray-400 px-2 py-0.5 rounded-full">
            <span data-pt="Rascunho" data-en="Draft">Rascunho</span>
          </span>
        )}
      </div>

      <h2 class="text-[15px] font-semibold mb-2 group-hover:text-primary transition-colors line-clamp-2 leading-snug">
        {title}
      </h2>

      {description && (
        <p class="text-sm text-gray-400 dark:text-gray-500 line-clamp-2 leading-relaxed mb-3">
          {description}
        </p>
      )}

      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3 text-[11px] text-gray-400 dark:text-gray-500">
          <time datetime={formatDate(date)}>{formatDate(date)}</time>
          {wordCount > 0 && (
            <>
              <span class="w-px h-3 bg-gray-200 dark:bg-gray-700"></span>
              <span>{wordCount} <span data-pt="palavras" data-en="words">palavras</span></span>
            </>
          )}
        </div>
        <span class="text-[11px] text-primary opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center gap-1">
          <span data-pt="Ler" data-en="Read">Ler</span>
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </div>
    </div>
  </a>

  {tags.length > 0 && (
    <div class="px-5 pb-4 flex flex-wrap gap-1.5">
      {tags.slice(0, 3).map((tag) => (
        <a
          href={`/tags/${tag}`}
          class="text-[10px] px-2 py-0.5 rounded-full bg-gray-50 dark:bg-white/[0.03] text-gray-400 dark:text-gray-500 hover:text-primary dark:hover:text-primary hover:bg-primary/5 dark:hover:bg-primary/10 transition-all border border-gray-100/50 dark:border-white/[0.03]"
        >
          {tag}
        </a>
      ))}
      {tags.length > 3 && (
        <span class="text-[10px] px-2 py-0.5 text-gray-300 dark:text-gray-600">
          +{tags.length - 3}
        </span>
      )}
    </div>
  )}
</article>
